# ═══════════════════════════════════════════════════════════════
# إعدادات بوت Pocket Option
# انسخ هذا الملف إلى .env وعدّل القيم
# ═══════════════════════════════════════════════════════════════

# توكن بوت تليجرام (مطلوب)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# قاعدة بيانات PostgreSQL (اختياري - يستخدم SQLite إذا لم يُحدد)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# مفتاح Alpha Vantage (اختياري - مجاني)
# احصل عليه من: https://www.alphavantage.co/support/#api-key
# ALPHA_VANTAGE_KEY=your_key_here

# مفتاح Twelve Data (اختياري - مجاني)
# احصل عليه من: https://twelvedata.com/pricing
# TWELVE_DATA_KEY=your_key_here
